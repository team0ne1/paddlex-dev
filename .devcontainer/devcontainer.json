{
    "name": "PaddleX Dev Env",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            // 这里利用 host.docker.internal 指向宿主机的代理端口
            // "HTTP_PROXY": "http://host.docker.internal:20884",
            // "HTTPS_PROXY": "http://host.docker.internal:20884",
            // "NO_PROXY": "localhost,127.0.0.1"
        }
    },
    
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3.10",
                "python.analysis.extraPaths": ["/workspace/PaddleX"],
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "formulahendry.acp-client"
            ]
        }
    },

    // 将工作区挂载到容器的 /workspace
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "workspaceFolder": "/workspace",

    // 参考 PaddleX 官方文档的 Docker 运行参数
    "runArgs": [
        "--gpus", "all",
        "--shm-size=8g"
    ],

    "hostRequirements": {
        "gpu": true
    },

    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/tmp/host-gitconfig,type=bind,readonly"
    ],

    // 创建后执行的命令：直接指定 python3.10 安装当前项目的依赖
    "postCreateCommand": "npm install -g openclaw && bash .devcontainer/setup-git.sh && cd PaddleX && python3.10 -m pip install -e '.[base]' && paddlex --install PaddleOCR PaddleClas",

    // 引入官方 Git Feature，VS Code 会自动注入凭据助手 (GIT_ASKPASS) 实现凭据转发
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22",
            "nodeGypDependencies": true
        }
    },

    // 端口转发
    "forwardPorts": [8040, 8000, 18789],

    // 连接后以 root 用户运行
    "remoteUser": "root",

    "containerEnv": {
      "OPENCLAW_ALLOW_INSECURE_PRIVATE_WS": "1"
    }
}